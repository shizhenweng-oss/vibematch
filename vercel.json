{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    }
  },
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/_ /backend/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/_/backend/(.*)",
      "dest": "backend/main.py"
    }
  ]
}
